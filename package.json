{
  "name": "sellabot-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server that exposes marketplace seller operations (Shopee first) as tools Claude can call.",
  "type": "module",
  "bin": {
    "sellabot-mcp": "dist/index.js"
  },
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "authorize": "tsx scripts/authorize.ts",
    "authorize:manual": "tsx scripts/authorize.ts --manual",
    "check-key": "tsx scripts/check-key.ts",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.scripts.json",
    "test": "node --import tsx --test \"test/**/*.test.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.18.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
