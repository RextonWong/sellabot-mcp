# ── Shopee Open Platform ─────────────────────────────────────────
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_REGION=MY                # SG | MY | ID | TH | VN | PH | TW | BR
SHOPEE_ENV=sandbox              # sandbox | production
SHOPEE_SHOP_ID=                 # filled in after `npm run authorize`
SHOPEE_REDIRECT_URL=http://localhost:8787/callback

# ── Token storage (encrypted at rest) ────────────────────────────
TOKEN_DB_PATH=./.data/tokens.db
TOKEN_ENCRYPTION_KEY=           # 32-byte key (hex = 64 chars, or base64) for AES-256-GCM
SHOPEE_SEED_TOKEN=              # JSON token record from `npm run export-tokens` (cloud deployments only)

# ── OAuth callback server (used only by `npm run authorize`) ──────
OAUTH_CALLBACK_PORT=8787

# ── Server behavior ──────────────────────────────────────────────
READ_ONLY=false                 # true = expose only READ-tier (get_*) tools
LOG_LEVEL=info                  # debug | info | warn | error
REQUEST_TIMEOUT_MS=15000
MAX_RETRIES=3

# ── Consent & safety (see CLAUDE.md §3) ──────────────────────────
AUTO_CONFIRM_TIER=none          # none | routine  (SENSITIVE & CRITICAL can NEVER be auto-confirmed)
BULK_CONFIRM_THRESHOLD=10       # re-prompt for bulk_* operations affecting more than N items
AUDIT_LOG_PATH=./.data/audit.log  # append-only record of proposed/approved/executed actions

# ── Daemon / Notifications (required for `npm run daemon`) ───────
NOTIFY_EMAIL=                   # email to receive notifications
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                      # Gmail address (sender)
SMTP_PASS=                      # Gmail App Password (NOT your login password)
NTFY_TOPIC=                     # ntfy.sh topic for push notifications (e.g. sellabot-abc123)
TELEGRAM_BOT_TOKEN=             # from @BotFather — enables Telegram command bot + notifications
TELEGRAM_CHAT_ID=               # your numeric Telegram user ID (from @userinfobot)
LOW_STOCK_THRESHOLD=5
TIMEZONE=Asia/Kuala_Lumpur
AUTO_REPLY_REVIEWS=false        # true = auto-reply to 4-5 star reviews with thank-you templates
AUTO_ACCEPT_UNPAID_CANCELLATIONS=false  # true = auto-accept cancellations on unpaid orders
RESTOCK_ALERT_DAYS=7            # alert when a product will run out within N days

# ── Phase 3 — Shopee promotions (runs Sunday 9 AM) ───────────────
AUTO_CREATE_VOUCHER=false       # true = create a weekend % discount voucher every Sunday
WEEKLY_VOUCHER_DISCOUNT=5       # percent off (1-90)
AUTO_BOOST_LISTINGS=false       # true = generate a boost recommendation every Sunday
BOOST_TOP_N=3                   # how many listings to pick when no specific IDs are set
BOOST_PRODUCT_IDS=              # comma-separated product IDs to boost, e.g. 123,456,789
                                # overrides BOOST_TOP_N when set
BOOST_AUTO_EXECUTE=false        # ⚠️ costs Shopee credits — default is preview/recommend only
                                # set true only when you're sure you want auto-spending

# ── Phase 3 — Weekly ad pack (runs Sunday 9 AM) ──────────────────
AD_GENERATOR_ENABLED=true       # true = email a copy-paste ad pack every Sunday
AD_PRODUCTS_LIMIT=5             # how many products to generate ads for
ANTHROPIC_API_KEY=              # leave empty = template mode; set sk-ant-... = Claude AI copy
AGENT_MODEL=claude-sonnet-5    # model for the Manager Agent (default: claude-sonnet-5)

# ── Phase 4 — Instagram auto-posting ─────────────────────────────
# Setup: Meta Developer App → Instagram Graph API → get a long-lived user token
# 1. Go to developers.facebook.com → My Apps → create an app
# 2. Add "Instagram Graph API" product
# 3. Generate a User Token with instagram_content_publish permission
# 4. Exchange for long-lived token (valid 60 days):
#    GET https://graph.facebook.com/oauth/access_token
#       ?grant_type=fb_exchange_token&client_id={app_id}&client_secret={app_secret}&fb_exchange_token={short_token}
# 5. Find your Instagram User ID:
#    GET https://graph.facebook.com/v21.0/me?fields=instagram_business_account&access_token={token}
INSTAGRAM_ACCESS_TOKEN=         # long-lived user access token (60 days)
INSTAGRAM_USER_ID=              # your Instagram Business Account numeric ID
AUTO_POST_INSTAGRAM=false       # true = auto-post to Instagram every Sunday with the ad pack

# ── Cloud deployment (Render) ─────────────────────────────────────
ROUTINE_STATE_PATH=             # set to /data/routine-state.json on Render (empty = local .data/)

# ── Future platforms (placeholders, unused in v1) ────────────────
# LAZADA_APP_KEY=
# LAZADA_APP_SECRET=
# TIKTOK_APP_KEY=
# TIKTOK_APP_SECRET=
